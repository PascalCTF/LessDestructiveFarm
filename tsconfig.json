{
  "compilerOptions": {
    "target": "es6",
    "baseUrl": ".",
    "sourceMap": true,
    "outDir": "./build",
    "rootDir": "./src",
    "downlevelIteration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": [
      "./typings"
    ],
    "allowJs": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "commonjs",
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "incremental": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "typings/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "files": [
    "src/server.ts"
  ]
}
